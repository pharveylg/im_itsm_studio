# ═══════════════════════════════════════════════════════
# ITSM Service Delivery — Analysis Studio
# Environment Variables
# ═══════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────
# Local development:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# Supabase (use the "Connection string → URI" from your project settings):
# DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# ── AI Providers ──────────────────────────────────────
# Configure through the UI at /settings → AI Analysis Engine.
# Or set a default key here for the first provider:

# OpenAI
# AI_API_KEY=sk-...

# Anthropic (alternative — configure via UI)
# ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI / M365 Copilot (configure endpoint + key via UI)
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions
